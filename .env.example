# ─────────────────────────────────────────────────────────────
# Pool App Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Your ScreenLogic gateway IP address.
# Find it in your router's DHCP table — look for a device
# named "Pentair" or similar.
# Leave blank to use UDP auto-discovery (only works if the VM
# is on the same subnet as the gateway, no VLANs in between).
SL_IP=192.168.1.50

# Gateway port — almost always 80, don't change unless you know why
SL_PORT=80
